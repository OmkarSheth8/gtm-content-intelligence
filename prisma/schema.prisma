// GTM Content Intelligence Engine — Prisma Schema
// Run `npx prisma generate` then `npx prisma db push` to apply to Supabase

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per channel/account per platform
model PlatformAccount {
  id          String   @id @default(cuid())
  platform    String   // "youtube" | "linkedin" | ...
  accountId   String   // YouTube channel ID
  accountName String
  metadata    Json?    // platform-specific extras
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contentItems    ContentItem[]
  recommendations Recommendation[]
  syncRuns        SyncRun[]

  @@unique([platform, accountId])
  @@map("platform_accounts")
}

// One row per video/post; never deleted, only updated for mutable fields
model ContentItem {
  id                String   @id @default(cuid())
  platformAccountId String
  platform          String   // denormalized for fast queries
  platformContentId String   // YouTube video ID
  title             String
  description       String?  @db.Text
  publishedAt       DateTime
  url               String
  thumbnailUrl      String?
  duration          Int?     // seconds
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  platformAccount PlatformAccount         @relation(fields: [platformAccountId], references: [id])
  metricSnapshots ContentMetricSnapshot[]
  classification  ContentClassification?
  events          ContentEvent[]

  @@unique([platform, platformContentId])
  @@index([platformAccountId])
  @@index([publishedAt])
  @@index([platform])
  @@map("content_items")
}

// Append-only; never overwrite — always insert a new snapshot
model ContentMetricSnapshot {
  id            String   @id @default(cuid())
  contentItemId String
  snapshotAt    DateTime @default(now())
  views         BigInt   @default(0)
  likes         Int      @default(0)
  comments      Int      @default(0)
  shares        Int?
  metadata      Json?    // platform-specific extras

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId, snapshotAt])
  @@map("content_metric_snapshots")
}

// One classification row per content item (upserted by the AI classifier)
model ContentClassification {
  id              String   @id @default(cuid())
  contentItemId   String   @unique
  topic           String?  // "Sales Enablement", "PLG", ...
  format          String?  // "tutorial" | "case-study" | "opinion" | "listicle"
  hook            String?  // "question" | "stat" | "story" | "contrarian"
  angle           String?  // "beginner" | "advanced" | "comparison" | "how-to"
  funnelStage     String?  // "awareness" | "consideration" | "decision"
  audiencePersona String?  // "SDR" | "VP Sales" | "RevOps" | ...
  classifiedAt    DateTime @default(now())
  classifiedBy    String   @default("llm") // "llm" | "manual"
  modelVersion    String?  // e.g. "claude-sonnet-4-6"

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@map("content_classifications")
}

// Downstream ROI proxy events — never overwrite, always append
model ContentEvent {
  id            String   @id @default(cuid())
  contentItemId String
  eventType     String   // "click" | "landing_page_view" | "demo_request" | "lead"
  sessionId     String?
  referrer      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId, eventType])
  @@index([createdAt])
  @@map("content_events")
}

// Generated by the recommendation engine; historical record kept
model Recommendation {
  id                 String   @id @default(cuid())
  generatedAt        DateTime @default(now())
  topic              String
  format             String
  hook               String
  angle              String
  reasoning          String   @db.Text
  historicalExamples Json?    // array of content item IDs used as evidence
  confidenceScore    Float    // 0–1
  expectedOutcome    String?
  status             String   @default("active") // "active" | "dismissed" | "used"
  modelVersion       String?
  platformAccountId  String?  // null for pre-migration seed rows

  platformAccount PlatformAccount? @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)

  @@index([generatedAt])
  @@index([status])
  @@index([platformAccountId, status, modelVersion])
  @@map("recommendations")
}

// One row per scheduled or manual sync attempt
model SyncRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  status            String    @default("running") // "running" | "success" | "failed"
  platform          String
  trigger           String    @default("cron") // "cron" | "manual"
  recordsPulled     Int?
  recordsUpserted   Int?
  snapshotsInserted Int?
  error             String?   @db.Text
  metadata          Json?
  platformAccountId String?   // null for pre-migration rows

  platformAccount PlatformAccount? @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)

  @@index([status, startedAt])
  @@index([platformAccountId, startedAt])
  @@index([platformAccountId, status])
  @@map("sync_runs")
}